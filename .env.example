# ─────────────────────────────────────────────────────────────────────────────
# Browser-exposed (public client identifiers — safe to ship in the bundle).
# Without these the avatar widget is skipped and the site runs unchanged.
# Put real values in a local .env.local (gitignored).
# ─────────────────────────────────────────────────────────────────────────────
VITE_DID_AGENT_ID=
VITE_DID_CLIENT_KEY=
# Optional — override the embed script URL (defaults to the D-ID v2 embed).
# VITE_DID_EMBED_SRC=https://agent.d-id.com/v2/index.js

# ─────────────────────────────────────────────────────────────────────────────
# Server-side only — used by the bootstrap scripts (npm run bootstrap:*).
# NEVER VITE_-prefixed (never shipped to the browser). Keep in .env (gitignored).
# ─────────────────────────────────────────────────────────────────────────────

# Option A — native D-ID agent (primary). Basic-auth key from D-ID Studio.
D_ID_API_KEY=
# D_ID_API_BASE=https://api.d-id.com
# Existing agent to PATCH (keeps your avatar/voice); omit to create a fresh one.
# DID_AGENT_ID=v2_agt_xxxxxxxx

# Option B — ElevenLabs agent (driven through D-ID's external_agent integration).
ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=cjVigY5qzO86Huf0OWal
# ELEVENLABS_LLM=gpt-4.1
