# D-ID Agents embed (talking avatar + voice navigation).
# Create the agent in D-ID Studio (https://studio.d-id.com/), bootstrap it with
# agent/tools.json + agent/instructions.md, then copy the values into a local
# .env.local file. Without these the avatar widget is skipped and the site runs unchanged.

VITE_DID_AGENT_ID=
VITE_DID_CLIENT_KEY=

# Optional — override the embed script URL (defaults to the D-ID v2 embed).
# VITE_DID_EMBED_SRC=https://agent.d-id.com/v2/index.js
